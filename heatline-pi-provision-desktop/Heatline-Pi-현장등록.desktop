[Desktop Entry]
Version=1.0
Type=Application
Name=Heatline Pi 현장등록
Comment=시리얼번호/프로비전키 입력 후 Pi 서비스 재시작 및 상태 확인
Exec=/bin/bash -lc 'cd ~/heatline-pi-provision-desktop && ./run_heatline_pi_helper.sh'
Path=/home/pi/heatline-pi-provision-desktop
Terminal=false
Categories=Utility;
StartupNotify=true
Icon=utilities-terminal
